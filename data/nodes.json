[
    { "id": "韩愈", "group": "transition", "type": "person", "era": "唐代", "desc": "唐代文学家、思想家，宋明理学先驱。推崇儒学，著《原道》，对《大学》和《中庸》的重视深刻影响了后来的理学家。" },
    { "id": "李翱", "group": "transition", "type": "person", "era": "唐代", "desc": "唐代思想家，韩愈的学生。著《复性书》，阐发《中庸》思想，提出'复性'说，为宋代理学心性论奠定基础。" },
    { "id": "周敦颐", "group": "neo_confucianism", "type": "person", "era": "北宋", "desc": "濂学创始人，提出'无极而太极'，开启宋明理学先声。" },
    { "id": "张载", "group": "qi_school", "type": "person", "era": "北宋", "desc": "关学创始人，提出'太虚即气'，'为天地立心'。重视《大学》《中庸》，继承韩愈、李翱的道统思想。" },
    { "id": "程颢", "group": "neo_confucianism", "type": "person", "era": "北宋", "desc": "洛学创始人之一，主张'天人本无二'，偏向心学。与程颐共同推崇《大学》《中庸》。" },
    { "id": "程颐", "group": "neo_confucianism", "type": "person", "era": "北宋", "desc": "洛学创始人之一，提出'性即理'，强调格物穷理。重视《大学》《中庸》，继承唐代儒学复兴传统。" },
    { "id": "朱熹", "group": "neo_confucianism", "type": "person", "era": "南宋", "desc": "闽学创始人，理学集大成者。主张'理在气先'，'格物致知'。将《大学》《中庸》与《论语》《孟子》并列为'四书'。" },
    { "id": "陆九渊", "group": "mind_school", "type": "person", "era": "南宋", "desc": "心学开创者。主张'心即理'，'宇宙便是吾心'。" },
    { "id": "吕祖谦", "group": "neo_confucianism", "type": "person", "era": "南宋", "desc": "婺学代表，调和朱陆，编撰《近思录》。" },
    { "id": "王守仁", "group": "mind_school", "type": "person", "era": "明代", "desc": "号阳明，心学集大成者。提出'知行合一'，'致良知'。" },
    { "id": "陈献章", "group": "mind_school", "type": "person", "era": "明代", "desc": "白沙先生，明代心学先驱，主张'静中养出端倪'。" },
    { "id": "罗钦顺", "group": "qi_school", "type": "person", "era": "明中期", "desc": "气学先驱，批判朱陆，主张'理只是气之理'。" },
    { "id": "王廷相", "group": "qi_school", "type": "person", "era": "明中期", "desc": "主张'元气之上无物'，彻底否定理的独立性。" },
    { "id": "刘宗周", "group": "transition", "type": "person", "era": "明末", "desc": "蕺山学派，主张'慎独'，试图挽救心学流弊。" },
    { "id": "黄宗羲", "group": "qi_school", "type": "person", "era": "清初", "desc": "师承刘宗周，编《明儒学案》，主张'心即气'。" },
    { "id": "顾炎武", "group": "practical_school", "type": "person", "era": "清初", "desc": "实学代表，主张'经世致用'，痛斥'清谈误国'。" },
    { "id": "王夫之", "group": "qi_school", "type": "person", "era": "清初", "desc": "船山先生，气学集大成。主张'天下惟器'，'理在气中'。" },
