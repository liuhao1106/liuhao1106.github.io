    { "id": "《大学》", "group": "concept", "type": "concept", "desc": "《礼记》中的一篇，韩愈、李翱推崇，程朱理学将其列为'四书'之首，强调'三纲领八条目'。" },
    { "id": "《中庸》", "group": "concept", "type": "concept", "desc": "《礼记》中的一篇，李翱《复性书》阐发其思想，程朱理学列为'四书'之一，阐述'中庸之道'与心性修养。" },
